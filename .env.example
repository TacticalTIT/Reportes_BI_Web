# Copie este archivo a .env.local y complete los valores.
# https://authjs.dev/reference/core/errors#missingsecret

AUTH_SECRET=

# Usuario de demostración (debe coincidir exactamente en el login)
AUTH_DEMO_USERNAME=

# Hash bcrypt en Base64 (Next.js expande $ en .env y rompe el hash plano).
# demo123 → ejemplo abajo. Para otra contraseña:
# node -e "const b=require('bcryptjs');console.log(Buffer.from(b.hashSync('TU_PASS',10)).toString('base64'))"
AUTH_DEMO_PASSWORD_HASH_B64=

# Opcional en desarrollo local
# AUTH_URL=http://localhost:3000

# URL base del API de reportes (sin barra final). Ej. https://tu-tunel.trycloudflare.com
REPORTES_API_BASE_URL=
NEXT_PUBLIC_REPORTES_API_BASE_URL=
